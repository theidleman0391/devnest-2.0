{
  "scripts": {
    "build:js": "node build.mjs",
    "build:css": "tailwindcss -i src/tailwind.css -o dist/styles.css --minify",
    "build:fonts": "node scripts/copy-fonts.mjs",
    "build:assets": "node scripts/compress-assets.mjs",
    "build": "npm run build:js && npm run build:css && npm run build:fonts",
    "watch:css": "tailwindcss -i src/tailwind.css -o dist/styles.css --watch",
    "dev": "node build.mjs --watch"
  },
  "dependencies": {
    "puppeteer": "^24.41.0"
  },
  "devDependencies": {
    "@fontsource/barlow": "^5.2.8",
    "@fontsource/instrument-serif": "^5.2.8",
    "esbuild": "^0.24.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.14"
  }
}
