{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/servicios", "destination": "/Services.html" },
    { "source": "/precios", "destination": "/Pricing.html" },
    { "source": "/portafolio", "destination": "/Work.html" },
    { "source": "/proceso", "destination": "/Process.html" },
    { "source": "/terminos", "destination": "/Terminos.html" },
    { "source": "/privacidad", "destination": "/Privacidad.html" }
  ],
  "buildCommand": "exit 0",
  "outputDirectory": ".",
  "headers": [

    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
